#!/bin/sh
set -e

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/winnotifier"
config_file="$config_dir/config"
version_file="$config_dir/version"
repo_owner="yuuan"
repo_name="WinNotifier"
script_path="tools/notify-sh/winnotify"

show_help() {
  cat <<HELP
Usage: winnotify -t <title> -m <message> [-i <icon>] [-f <from>]

Options:
  -t, --title    Notification title (required)
  -m, --message  Notification message (required)
  -i, --icon     Emoji icon (e.g. rocket, :bell:)
  -f, --from     Sender name
  -h, --help     Show this help
  --init         Create a sample config file
  --configure    Open the config file in an editor
  --icons        Show available emoji icons
  --version      Show installed version (commit hash)
  --self-update  Update to the latest version from GitHub

Config:
  File: $config_file
  Env:  WINNOTIFIER_ENDPOINT, WINNOTIFIER_TOKEN
HELP
  exit 0
}

open_config() {
  if [ ! -f "$config_file" ]; then
    echo "Config file not found: $config_file" >&2
    echo "Run 'winnotify --init' to create one." >&2
    exit 1
  fi
  editor="${VISUAL:-${EDITOR:-vi}}"
  exec "$editor" "$config_file"
}

show_icons() {
  # Load config to get endpoint
  endpoint="" token=""
  if [ -f "$config_file" ]; then
    . "$config_file"
  fi
  endpoint="${WINNOTIFIER_ENDPOINT:-$endpoint}"

  if [ -z "$endpoint" ]; then
    echo "Error: endpoint not configured. Run 'winnotify --init' first." >&2
    exit 1
  fi

  curl -sS -H "Accept: text/plain" "$endpoint/icons" 2>/dev/null | "${PAGER:-less}"
  exit 0
}

show_version() {
  if [ -f "$version_file" ]; then
    hash=$(cat "$version_file")
    echo "winnotify ${hash}"
  else
    echo "winnotify unknown"
  fi
  exit 0
}

update_self() {
  script="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"

  # Get latest commit hash from GitHub API
  latest=$(curl -sS "https://api.github.com/repos/${repo_owner}/${repo_name}/commits/main" \
    -H "Accept: application/vnd.github.sha" 2>/dev/null) || {
    echo "Error: failed to check for updates." >&2
    exit 1
  }

  if [ -z "$latest" ] || [ ${#latest} -ne 40 ]; then
    echo "Error: failed to get latest version from GitHub." >&2
    exit 1
  fi

  # Compare with installed version
  current=""
  if [ -f "$version_file" ]; then
    current=$(cat "$version_file")
  fi

  if [ "$current" = "$latest" ]; then
    echo "Already up to date. (${latest})"
    exit 0
  fi

  # Download latest script to a temp file
  tmpfile=$(mktemp) || {
    echo "Error: failed to create temporary file." >&2
    exit 1
  }
  trap 'rm -f "$tmpfile"' EXIT

  curl -sS -f "https://raw.githubusercontent.com/${repo_owner}/${repo_name}/main/${script_path}" \
    -o "$tmpfile" 2>/dev/null || {
    echo "Error: failed to download update." >&2
    exit 1
  }

  if [ ! -s "$tmpfile" ]; then
    echo "Error: downloaded file is empty." >&2
    exit 1
  fi

  chmod +x "$tmpfile"
  mv "$tmpfile" "$script" || {
    echo "Error: failed to replace script. Try: sudo winnotify --update" >&2
    exit 1
  }
  trap - EXIT

  # Save new version
  mkdir -p "$config_dir"
  printf '%s\n' "$latest" > "$version_file"

  echo "Updated: ${current:-unknown} -> ${latest}"
  exit 0
}

init_config() {
  if [ -f "$config_file" ]; then
    echo "Config file already exists: $config_file" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$config_file")"
  cat > "$config_file" <<'EOF'
# WinNotifier config
endpoint=http://localhost:8080
token=
EOF
  echo "Created: $config_file"
  exit 0
}

usage() {
  echo "Usage: winnotify -t <title> -m <message> [-i <icon>] [-f <from>]" >&2
  echo "Try 'winnotify --help' for more information." >&2
  exit 1
}

json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/	/\\t/g'
}

# Parse arguments
title="" message="" icon="" from=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)    show_help ;;
    --init)       init_config ;;
    --configure)  open_config ;;
    --icons)      show_icons ;;
    --version)    show_version ;;
    --self-update) update_self ;;
    -t|--title)   title="$2";   shift 2 ;;
    -m|--message) message="$2"; shift 2 ;;
    -i|--icon)    icon="$2";    shift 2 ;;
    -f|--from)    from="$2";    shift 2 ;;
    *) usage ;;
  esac
done

if [ -z "$title" ] || [ -z "$message" ]; then
  usage
fi

# Load config (file first, then env vars override)
endpoint="" token=""

if [ -f "$config_file" ]; then
  . "$config_file"
fi

endpoint="${WINNOTIFIER_ENDPOINT:-$endpoint}"
token="${WINNOTIFIER_TOKEN:-$token}"

if [ -z "$endpoint" ]; then
  cat >&2 <<MSG
Error: endpoint not configured.

Option 1: Create a config file
  mkdir -p "$(dirname "$config_file")"
  cat > "$config_file" <<'EOF'
  endpoint=http://<windows-ip>:8080
  token=<your-token>
  EOF

Option 2: Set environment variables
  export WINNOTIFIER_ENDPOINT=http://<windows-ip>:8080
  export WINNOTIFIER_TOKEN=<your-token>
MSG
  exit 1
fi

# Build JSON payload
json="{\"title\":\"$(json_escape "$title")\",\"message\":\"$(json_escape "$message")\""

if [ -n "$icon" ]; then
  json="$json,\"icon\":\"$(json_escape "$icon")\""
fi

if [ -n "$from" ]; then
  json="$json,\"from\":\"$(json_escape "$from")\""
fi

json="$json}"

# Build curl auth option
auth_opt=""
if [ -n "$token" ]; then
  auth_opt="-u :$token"
fi

# Send notification
curl -s -f $auth_opt -X POST "$endpoint/notify" \
  -H "Content-Type: application/json" \
  -d "$json" > /dev/null
